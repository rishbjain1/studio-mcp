# Provider-agnostic LLM layer — point at ANY OpenAI-compatible endpoint.
# Anthropic, OpenRouter, OpenAI, or a local server all work via these vars.

# Default: Anthropic (OpenAI-compatible endpoint)
STUDIO_LLM_BASE_URL=https://api.anthropic.com/v1
STUDIO_LLM_MODEL=claude-opus-4-8
# Optional: a separate vision-capable model for qc_still (defaults to STUDIO_LLM_MODEL)
# STUDIO_LLM_VISION_MODEL=claude-opus-4-8
STUDIO_LLM_API_KEY=sk-ant-...

# Where project state lives (one folder per project).
# STUDIO_ROOT=~/studio-projects

# --- v1.1 render (Higgsfield CLI) ---
# Install: npm i -g @higgsfield/cli && higgsfield auth login   (device OAuth, no key)
# Pick models with: higgsfield model list
# STUDIO_IMAGE_MODEL=          # Soul image model for gen_still
# STUDIO_VIDEO_MODEL=          # img2vid model for animate

# --- Examples for other providers ---
# OpenRouter:
#   STUDIO_LLM_BASE_URL=https://openrouter.ai/api/v1
#   STUDIO_LLM_MODEL=anthropic/claude-opus-4.8
#   STUDIO_LLM_API_KEY=sk-or-...
# OpenAI:
#   STUDIO_LLM_BASE_URL=https://api.openai.com/v1
#   STUDIO_LLM_MODEL=gpt-5.5
#   STUDIO_LLM_API_KEY=sk-...
